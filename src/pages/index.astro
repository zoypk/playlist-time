---
import App from "../components/App";
import "../styles/global.css";

const site = Astro.site?.toString() ?? "https://playlisttime.app";
const canonical = new URL("/", site).toString();
const title = "Playlist Time - Compare YouTube Playlist Duration at Multiple Speeds";
const description =
  "Analyze multiple YouTube playlists in one table, edit video ranges, and compare watch time at 1x, 1.25x, 1.5x, 1.75x, and custom speed.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Playlist Time",
  url: canonical,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any",
  description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  }
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Playlist Time" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spline+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="min-h-screen overflow-x-hidden selection:bg-primary/30">
    <header class="sticky top-0 z-40 border-b border-border-dark bg-surface-darker/95 px-6 py-3 shadow-md backdrop-blur">
      <div class="mx-auto flex w-full max-w-[1600px] items-center gap-3">
        <div class="flex size-8 items-center justify-center text-primary">
          <svg viewBox="0 0 24 24" class="size-7" fill="currentColor" aria-hidden="true">
            <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-2 5.8a.8.8 0 0 1 1.23-.67l5.23 3.37a.8.8 0 0 1 0 1.34l-5.23 3.37A.8.8 0 0 1 10 14.54V7.8Z" />
          </svg>
        </div>
        <span class="text-xl font-bold tracking-tight text-white">Playlist Time</span>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-[1600px] flex-1 flex-col gap-8 p-6">
      <section class="rounded-xl border border-border-dark bg-surface-dark">
        <div class="border-b border-border-dark px-5 py-4">
          <div>
            <h1 class="text-2xl font-bold text-white">Playlist Time</h1>
            <p class="mt-2 max-w-3xl text-sm text-gray-300">
              Compare total watch time across multiple playlists at several speeds at once, including a global custom speed.
              Edit ranges per playlist to estimate exactly how long your selected segments take.
            </p>
          </div>
        </div>
      </section>

      <section>
        <App client:idle />
      </section>

      <section id="seo-details" class="rounded-xl border border-border-dark bg-surface-dark/80 px-5 py-4">
        <details>
          <summary class="cursor-pointer text-sm font-semibold uppercase tracking-wide text-primary">How it works and FAQ</summary>
          <div class="mt-4 grid gap-6 lg:grid-cols-2">
            <section>
              <h2 class="text-sm font-semibold uppercase tracking-wider text-primary">How it works</h2>
              <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-gray-300">
                <li>Paste one or many playlist URLs/IDs and click Analyze.</li>
                <li>Set Default Range Start/End to apply an initial range for newly added playlists.</li>
                <li>Use the Range pill in each playlist row to fine-tune start/end per playlist.</li>
                <li>Compare watch time at 1x, 1.25x, 1.5x, 1.75x, and a global Custom speed.</li>
                <li>Click table headers to sort, then drag rows to override the current order.</li>
              </ul>
            </section>

            <section>
              <h2 class="text-sm font-semibold uppercase tracking-wider text-primary">FAQ</h2>
              <div class="mt-3 space-y-2 text-sm text-gray-300">
                <details class="rounded border border-border-dark bg-black/40 p-3">
                  <summary class="cursor-pointer font-medium text-gray-100">Do you use YouTube playlist view totals?</summary>
                  <p class="mt-2 text-gray-400">
                    No. The Views column sums video-level views in the playlist, not YouTube's aggregate playlist page views.
                  </p>
                </details>
                <details class="rounded border border-border-dark bg-black/40 p-3">
                  <summary class="cursor-pointer font-medium text-gray-100">Is the YouTube API key exposed in the browser?</summary>
                  <p class="mt-2 text-gray-400">
                    No. Requests go through Cloudflare Pages Functions, and YouTube keys stay in environment variables.
                  </p>
                </details>
                <details class="rounded border border-border-dark bg-black/40 p-3">
                  <summary class="cursor-pointer font-medium text-gray-100">Will my playlists stay after refresh?</summary>
                  <p class="mt-2 text-gray-400">
                    Yes. Playlist rows, selected ranges, sorting, and custom speed are saved locally in your browser.
                  </p>
                </details>
                <details class="rounded border border-border-dark bg-black/40 p-3">
                  <summary class="cursor-pointer font-medium text-gray-100">How does Custom speed work?</summary>
                  <p class="mt-2 text-gray-400">
                    Custom speed applies globally. Changing it updates the Custom column for every playlist and the totals row.
                  </p>
                </details>
              </div>
            </section>
          </div>
        </details>
      </section>
    </main>

  </body>
</html>

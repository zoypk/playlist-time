---
import App from "../components/App";
import { ContentAccordion } from "../components/ContentAccordion";
import "../styles/global.css";

const site = "https://yttime.pages.dev";
const canonical = new URL("/", site).toString();
const socialImage = new URL("/og.svg", site).toString();
const socialImageAlt = "Playlist Time — free YouTube Playlist Length Calculator";

const title = "YouTube Playlist Length Calculator — Playlist Time";
const description =
  "Calculate YouTube playlist duration instantly. See total playlist time at 1x, 1.25x, 1.5x, and custom speeds. Free online playlist calculator — no login needed.";

const faq = [
  {
    q: "How do I calculate YouTube playlist duration?",
    a: "Paste one or more playlist URLs into the input field and click Analyze. Playlist Time fetches every video in the playlist, sums their durations, and shows you the total YouTube playlist time in hours, minutes, and seconds."
  },
  {
    q: "How long is a YouTube playlist at 1.5x speed?",
    a: "Playlist Time divides the total duration by the playback speed you choose. For example, a 10-hour playlist takes about 6 hours 40 minutes at 1.5x speed. You can also check 1.25x, 1.75x, or set any custom speed."
  },
  {
    q: "Can I compare multiple playlists at once?",
    a: "Yes. Paste multiple playlist URLs or IDs separated by a new line, comma, or space. The playlist watch time calculator creates one row per playlist plus a combined totals row so you can compare them side by side."
  },
  {
    q: "Can I calculate only part of a playlist?",
    a: "Absolutely. Use the Start and End fields to measure a specific range of videos — for example, videos 20 through 80. You can set a default range for all playlists or override it individually."
  },
  {
    q: "Why might the total differ from what I expect?",
    a: "Totals can change if a playlist contains unavailable videos (private, deleted, or region-blocked) or if the playlist owner adds or removes videos after your analysis. Minor differences may also come from rounding."
  },
  {
    q: "Is my data stored anywhere?",
    a: "No. Playlist Time runs entirely in your browser. Any saved data is stored locally so your list can persist on refresh. Nothing is uploaded to a server or shared publicly."
  }
];

const howItWorks = [
  { title: "Paste playlist links or IDs", detail: "Add one or many YouTube playlist URLs — separated by a new line, comma, or space." },
  { title: "Set an optional range", detail: "Apply a Start and End range to newly added playlists. Great for large courses where you only need a specific section." },
  { title: "Click Analyze", detail: "The tool fetches every video, sums the durations, and builds a comparison table in seconds." },
  { title: "Fine-tune per playlist", detail: "Adjust the Start/End range on individual rows to measure exactly the videos you care about." },
  { title: "Compare speeds instantly", detail: "See totals at 1x, 1.25x, 1.5x, 1.75x, and any custom playback speed you set." }
];

const features = [
  { title: "Multiple playlist support", detail: "Analyze as many playlists as you want in a single session and compare them side by side." },
  { title: "Flexible speed control", detail: "Preset columns for 1x, 1.25x, 1.5x, and 1.75x — plus a custom speed slider for any pace." },
  { title: "Per-playlist video ranges", detail: "Set a global default range or override it for each playlist to calculate partial durations." },
  { title: "No login required", detail: "Completely free. No sign-up, no ads, and no data leaves your browser." },
  { title: "Instant results", detail: "Results appear in seconds. Works on desktop, tablet, and mobile browsers." }
];

const whyUse = "Whether you are planning a study schedule, estimating a tutorial series, or figuring out how long a binge-watch will take, knowing the total YouTube playlist time saves real effort. Instead of scrolling through dozens — or hundreds — of videos to guess, this online playlist calculator gives you an accurate answer in seconds. Compare playlist duration at 1.5x speed or any other rate so you can plan around your actual listening habits.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Playlist Time",
      url: canonical,
      description
    },
    {
      "@type": "WebApplication",
      name: "Playlist Time",
      url: canonical,
      applicationCategory: "UtilityApplication",
      operatingSystem: "Any",
      description,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a }
      }))
    }
  ]
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0A0D15" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.svg" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#E11D48" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Playlist Time" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="min-h-screen">
    <a href="#calculator" class="skip-link">Skip to calculator</a>

    <header
      class="sticky top-0 z-40 border-b border-border-dark bg-surface-darker/90 shadow-soft backdrop-blur"
    >
      <div class="site-frame flex items-center gap-3 py-3">
        <a href="/" class="flex items-center gap-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" aria-label="Playlist Time home">
        <div class="flex size-8 items-center justify-center rounded-md bg-primary/10 text-primary ring-1 ring-primary/30">
          <svg viewBox="0 0 24 24" class="size-7" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-2 5.8a.8.8 0 0 1 1.23-.67l5.23 3.37a.8.8 0 0 1 0 1.34l-5.23 3.37A.8.8 0 0 1 10 14.54V7.8Z"
            />
          </svg>
        </div>
        <span class="text-xl font-bold text-white">Playlist Time</span>
        </a>

        <nav class="ml-auto hidden items-center gap-1 sm:flex" aria-label="Primary navigation">
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-warm-muted transition hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" href="#calculator">
            Calculator
          </a>
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-warm-muted transition hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" href="#seo-content">
            Guide
          </a>
        </nav>
      </div>
    </header>

    <main class="site-frame flex flex-1 flex-col gap-5 py-5">
      <section class="overflow-hidden rounded-lg border border-border-dark bg-surface-dark/80 shadow-lift">
        <div class="grid md:grid-cols-[minmax(0,1.35fr)_minmax(280px,0.65fr)]">
          <div class="p-5 md:p-6">
            <p class="text-sm font-semibold text-primary">Playlist Time</p>
            <h1 class="mt-2 max-w-3xl font-display text-3xl font-extrabold leading-tight text-white">
              YouTube playlist length calculator
            </h1>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-warm-muted">
              Compare total watch time across playlists, playback speeds, and video ranges without signing in.
            </p>
          </div>

          <aside class="border-t border-border-dark bg-surface-darker/80 p-5 md:border-l md:border-t-0" aria-label="Calculator summary">
            <dl class="grid gap-2 sm:grid-cols-3 md:grid-cols-1">
              <div class="rounded-md border border-border-dark bg-surface-raised/60 p-3 shadow-inset">
                <dt class="text-xs font-medium text-warm-muted">Baseline</dt>
                <dd class="mt-1 font-mono text-lg font-bold text-white">1x</dd>
              </div>
              <div class="rounded-md border border-border-dark bg-surface-raised/60 p-3 shadow-inset">
                <dt class="text-xs font-medium text-warm-muted">Custom</dt>
                <dd class="mt-1 font-mono text-lg font-bold text-white">0.1-3x</dd>
              </div>
              <div class="rounded-md border border-border-dark bg-surface-raised/60 p-3 shadow-inset">
                <dt class="text-xs font-medium text-warm-muted">Ranges</dt>
                <dd class="mt-1 font-mono text-lg font-bold text-white">Start/end</dd>
              </div>
            </dl>
          </aside>
        </div>
      </section>

      <section id="calculator" aria-label="Playlist calculator">
        <App client:idle />
      </section>

      {/* SEO + helpful content (accordion) */}
      <section id="seo-content" class="overflow-hidden rounded-lg border border-border-dark bg-surface-dark/70 shadow-soft">
        <ContentAccordion client:idle faq={faq} howItWorks={howItWorks} features={features} whyUse={whyUse} />
      </section>
    </main>
  </body>
</html>

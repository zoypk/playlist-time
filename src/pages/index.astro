---
import App from "../components/App";
import { ContentAccordion } from "../components/ContentAccordion";
import "../styles/global.css";

const site = "https://yttime.pages.dev";
const canonical = new URL("/", site).toString();
const socialImage = new URL("/og.svg", site).toString();
const socialImageAlt = "Playlist Time: YouTube playlist duration calculator";

const title = "Playlist Time — YouTube Playlist Duration Tool";
const description =
  "Calculate total YouTube playlist duration, edit video ranges, and compare watch time across multiple playlists at 1x, 1.25x, 1.5x, 1.75x, and custom speed.";

const faq = [
  {
    q: "What is Playlist Time?",
    a: "Playlist Time is a YouTube playlist duration and watch-time calculator. It adds up video lengths in one or more playlists and shows how long they take to watch at different playback speeds."
  },
  {
    q: "How do you calculate YouTube playlist duration?",
    a: "We fetch the videos in the playlist and sum their durations. The totals are then converted into estimates at 1x, 1.25x, 1.5x, 1.75x, and your custom speed."
  },
  {
    q: "Can I compare multiple playlists at once?",
    a: "Yes. Paste multiple playlist URLs or IDs and you’ll get one row per playlist plus a combined totals row."
  },
  {
    q: "Can I calculate only part of a playlist (a range of videos)?",
    a: "Yes. Use Start and End to calculate only a slice of the playlist (for example, videos 20–80). You can set a default range and also override the range per playlist."
  },
  {
    q: "How does playback speed change the total time?",
    a: "Playback speed is applied mathematically (Total time ÷ Speed). For example, a 10-hour playlist takes about 6 hours 40 minutes at 1.5x."
  },
  {
    q: "Why might my total differ from what I expect?",
    a: "Totals can change if a playlist contains unavailable videos (private, deleted, region-blocked) or if the playlist is updated after you analyze it. Small differences can also come from rounding in UI displays."
  },
  // {
  //   q: "Does this work for private or unlisted playlists?",
  //   a: "Public playlists work best. Private playlists usually can’t be analyzed unless your browser/session has access to the video data."
  // },
  {
    q: "Do you store my playlists or results?",
    a: "Playlist Time is designed for quick calculations. If anything is saved for convenience, it’s stored locally in your browser (so your list can persist on refresh) rather than being published as a public list."
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Playlist Time",
      url: canonical,
      description
    },
    {
      "@type": "WebApplication",
      name: "Playlist Time",
      url: canonical,
      applicationCategory: "UtilityApplication",
      operatingSystem: "Any",
      description,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a }
      }))
    }
  ]
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0A0D15" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.svg" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#E11D48" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Playlist Time" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <!-- DNS prefetch for faster font loading -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Preload fonts asynchronously to prevent render blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Spline+Sans:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Spline+Sans:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      />
    </noscript>
    
    <!-- Polyfill for browsers that don't support onload on link elements -->
    <script is:inline>
      !function(e){"use strict";var t=function(t,n,r){var o,i=e.document,s=i.createElement("link");if(n)o=n;else{var a=(i.body||i.getElementsByTagName("head")[0]).childNodes;o=a[a.length-1]}var l=i.styleSheets;s.rel="stylesheet",s.href=t,s.media="only x",function e(t){if(i.body)return t();setTimeout(function(){e(t)})}(function(){o.parentNode.insertBefore(s,n?o:o.nextSibling)});var d=function(e){for(var t=s.href,n=l.length;n--;)if(l[n].href===t)return e();setTimeout(function(){d(e)})};return s.addEventListener&&s.addEventListener("load",function(){this.media=r||"all"}),s.onloadcssdefined=d,d(function(){s.media!==r&&(s.media=r||"all")}),s};"undefined"!=typeof exports?exports.loadCSS=t:e.loadCSS=t}("undefined"!=typeof global?global:this);
    </script>

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="min-h-screen overflow-x-hidden selection:bg-primary/30">
    <header
      class="sticky top-0 z-40 border-b border-border-dark bg-surface-darker/95 px-6 py-3 shadow-md backdrop-blur"
    >
      <div class="mx-auto flex w-full max-w-[1600px] items-center gap-3">
        <div class="flex size-8 items-center justify-center text-primary">
          <svg viewBox="0 0 24 24" class="size-7" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-2 5.8a.8.8 0 0 1 1.23-.67l5.23 3.37a.8.8 0 0 1 0 1.34l-5.23 3.37A.8.8 0 0 1 10 14.54V7.8Z"
            />
          </svg>
        </div>
        <span class="text-xl font-bold tracking-tight text-white">Playlist Time</span>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-[1600px] flex-1 flex-col gap-8 p-6">
      <section class="rounded-xl border border-border-dark bg-surface-dark">
        <div class="border-b border-border-dark px-5 py-4">
          <div>
            <h1 class="text-2xl font-bold text-white" aria-label="Calculate Playlist Time">Calculate Playlist Time</h1>
            <p class="mt-2 max-w-3xl text-sm text-gray-300">
              Calculate YouTube playlist duration and compare watch time across multiple playlists at different playback speeds.
              Set a start/end range per playlist to estimate exactly how long specific sections take.
            </p>
          </div>
        </div>
      </section>

      <section>
        <App client:idle />
      </section>

      {/* SEO + helpful content (accordion) */}
      <section id="seo-content" class="rounded-xl border border-border-dark bg-surface-dark/80">
        <ContentAccordion client:visible {faq} />
      </section>
    </main>
  </body>
</html>

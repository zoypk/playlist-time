---
import App from "../components/App";
import { ContentAccordion } from "../components/ContentAccordion";
import "../styles/global.css";

const site = "https://yttime.pages.dev";
const canonical = new URL("/", site).toString();
const socialImage = new URL("/og.svg", site).toString();
const socialImageAlt = "Playlist Time — free YouTube Playlist Length Calculator";

const title = "YouTube Playlist Length Calculator — Playlist Time";
const description =
  "Calculate YouTube playlist duration instantly. See total playlist time at 1x, 1.25x, 1.5x, and custom speeds. Free online playlist calculator — no login needed.";

const faq = [
  {
    q: "How do I calculate YouTube playlist duration?",
    a: "Paste one or more playlist URLs into the input field and click Analyze. Playlist Time fetches every video in the playlist, sums their durations, and shows you the total YouTube playlist time in hours, minutes, and seconds."
  },
  {
    q: "How long is a YouTube playlist at 1.5x speed?",
    a: "Playlist Time divides the total duration by the playback speed you choose. For example, a 10-hour playlist takes about 6 hours 40 minutes at 1.5x speed. You can also check 1.25x, 1.75x, or set any custom speed."
  },
  {
    q: "Can I compare multiple playlists at once?",
    a: "Yes. Paste multiple playlist URLs or IDs separated by a new line, comma, or space. The playlist watch time calculator creates one row per playlist plus a combined totals row so you can compare them side by side."
  },
  {
    q: "Can I calculate only part of a playlist?",
    a: "Absolutely. Use the Start and End fields to measure a specific range of videos — for example, videos 20 through 80. You can set a default range for all playlists or override it individually."
  },
  {
    q: "Why might the total differ from what I expect?",
    a: "Totals can change if a playlist contains unavailable videos (private, deleted, or region-blocked) or if the playlist owner adds or removes videos after your analysis. Minor differences may also come from rounding."
  },
  {
    q: "Is my data stored anywhere?",
    a: "No. Playlist Time runs entirely in your browser. Any saved data is stored locally so your list can persist on refresh. Nothing is uploaded to a server or shared publicly."
  }
];

const howItWorks = [
  { title: "Paste playlist links or IDs", detail: "Add one or many YouTube playlist URLs — separated by a new line, comma, or space." },
  { title: "Set an optional range", detail: "Apply a Start and End range to newly added playlists. Great for large courses where you only need a specific section." },
  { title: "Click Analyze", detail: "The tool fetches every video, sums the durations, and builds a comparison table in seconds." },
  { title: "Fine-tune per playlist", detail: "Adjust the Start/End range on individual rows to measure exactly the videos you care about." },
  { title: "Compare speeds instantly", detail: "See totals at 1x, 1.25x, 1.5x, 1.75x, and any custom playback speed you set." }
];

const features = [
  { title: "Multiple playlist support", detail: "Analyze as many playlists as you want in a single session and compare them side by side." },
  { title: "Flexible speed control", detail: "Preset columns for 1x, 1.25x, 1.5x, and 1.75x — plus a custom speed slider for any pace." },
  { title: "Per-playlist video ranges", detail: "Set a global default range or override it for each playlist to calculate partial durations." },
  { title: "No login required", detail: "Completely free. No sign-up, no ads, and no data leaves your browser." },
  { title: "Instant results", detail: "Results appear in seconds. Works on desktop, tablet, and mobile browsers." }
];

const whyUse = "Whether you are planning a study schedule, estimating a tutorial series, or figuring out how long a binge-watch will take, knowing the total YouTube playlist time saves real effort. Instead of scrolling through dozens — or hundreds — of videos to guess, this online playlist calculator gives you an accurate answer in seconds. Compare playlist duration at 1.5x speed or any other rate so you can plan around your actual listening habits.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Playlist Time",
      url: canonical,
      description
    },
    {
      "@type": "WebApplication",
      name: "Playlist Time",
      url: canonical,
      applicationCategory: "UtilityApplication",
      operatingSystem: "Any",
      description,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      }
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a }
      }))
    }
  ]
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0A0D15" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.svg" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#E11D48" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Playlist Time" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="min-h-screen overflow-x-hidden selection:bg-primary/40">
    <header
      class="sticky top-0 z-40 border-b border-border-dark bg-surface-darker/95 px-6 py-3 shadow-md backdrop-blur"
    >
      <div class="mx-auto flex w-full max-w-[1600px] items-center gap-3">
        <div class="flex size-8 items-center justify-center text-primary">
          <svg viewBox="0 0 24 24" class="size-7" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-2 5.8a.8.8 0 0 1 1.23-.67l5.23 3.37a.8.8 0 0 1 0 1.34l-5.23 3.37A.8.8 0 0 1 10 14.54V7.8Z"
            />
          </svg>
        </div>
        <span class="text-xl font-bold tracking-tight text-white">Playlist Time</span>
      </div>
    </header>

    <main class="mx-auto flex w-full max-w-[1600px] flex-1 flex-col gap-8 p-6">
      <section class="rounded-xl border border-border-dark bg-surface-dark">
        <div class="border-b border-border-dark px-5 py-4">
          <div>
            <h1 class="text-2xl font-bold text-white">YouTube Playlist Length Calculator</h1>
            <p class="mt-2 max-w-3xl text-sm text-gray-300">
              Instantly calculate YouTube playlist duration and compare watch time at different playback speeds.
              Paste one or more playlist links, set optional video ranges, and see exactly how long each playlist takes to finish.
            </p>
          </div>
        </div>
      </section>

      <section>
        <App client:idle />
      </section>

      {/* SEO + helpful content (accordion) */}
      <section id="seo-content" class="rounded-xl border border-border-dark bg-surface-dark/80">
        <ContentAccordion client:idle faq={faq} howItWorks={howItWorks} features={features} whyUse={whyUse} />
      </section>
    </main>
  </body>
</html>

---
import App from "../components/App";
import { ContentAccordion } from "../components/ContentAccordion";
import "../styles/global.css";

const site = "https://playlist-time.pages.dev";
const canonical = new URL("/", site).toString();
const socialImage = new URL("/og.svg", site).toString();
const socialImageAlt = "yttime YouTube playlist length calculator with speed, range, planner, and export tools";

const title = "YouTube Playlist Length Calculator | yttime";
const description =
  "Calculate YouTube playlist length instantly. Compare multiple playlists, ranges, playback speeds, daily watch plans, and CSV summaries. Free, no login.";

const faq = [
  {
    q: "How do I calculate YouTube playlist duration?",
    a: "Paste one or more playlist URLs into the input field and click Analyze. yttime fetches every video in the playlist, sums their durations, and shows you the total YouTube playlist time in hours, minutes, and seconds."
  },
  {
    q: "How long is a YouTube playlist at 1.5x speed?",
    a: "yttime divides the total duration by the playback speed you choose. For example, a 10-hour playlist takes about 6 hours 40 minutes at 1.5x speed. You can also check 1.25x, 1.75x, 2x, or set any custom speed."
  },
  {
    q: "Can I compare multiple playlists at once?",
    a: "Yes. Paste multiple playlist URLs or IDs separated by a new line, comma, or space. The playlist watch time calculator creates one row per playlist plus a combined totals row so you can compare them side by side."
  },
  {
    q: "Can I calculate only part of a playlist?",
    a: "Yes. Use the Start and End fields to measure a specific range of videos, for example videos 20 through 80. You can set a default range for all playlists or override it individually."
  },
  {
    q: "Can I plan how many days a playlist will take?",
    a: "Yes. After analysis, the daily watch planner estimates days, finish date, and videos per day from your selected playback speed and daily minute goal."
  },
  {
    q: "Can I copy or export playlist duration results?",
    a: "Yes. Loaded results include copyable summaries and a CSV export with playlist title, channel, selected range, watch time, views, publish date, and YouTube URL."
  },
  {
    q: "What does the Views column represent?",
    a: "Views are shown as extra context. If available, the number is derived from video-level view counts and summed across the playlist. Watch time is always calculated from video durations, not from views."
  },
  {
    q: "Why might the total differ from what I expect?",
    a: "Totals can change if a playlist contains unavailable videos (private, deleted, or region-blocked) or if the playlist owner adds or removes videos after your analysis. Minor differences may also come from rounding."
  },
  {
    q: "Is my data stored anywhere?",
    a: "No account is needed. Playlist IDs are sent to the serverless API so it can query YouTube, but saved calculator state stays in your browser session and is not shared publicly."
  }
];

const howItWorks = [
  { title: "Paste playlist links or IDs", detail: "Add one or many YouTube playlist URLs separated by a new line, comma, or space." },
  { title: "Set an optional range", detail: "Apply a Start and End range to newly added playlists. Great for large courses where you only need a specific section." },
  { title: "Click Analyze", detail: "The tool fetches every video, sums the durations, and builds a comparison table in seconds." },
  { title: "Fine-tune per playlist", detail: "Adjust the Start/End range on individual rows to measure exactly the videos you care about." },
  { title: "Compare speeds instantly", detail: "See totals at 1x, 1.25x, 1.5x, 1.75x, 2x, and any custom playback speed you set." },
  { title: "Plan or export", detail: "Estimate a daily finish date, copy a text summary, or download CSV results for a study plan or team schedule." }
];

const features = [
  { title: "Multiple playlist support", detail: "Analyze as many playlists as you want in a single session and compare them side by side." },
  { title: "Flexible speed control", detail: "Preset columns for 1x, 1.25x, 1.5x, 1.75x, and 2x, plus a custom speed field for any pace from 0.1x to 3x." },
  { title: "Per-playlist video ranges", detail: "Set a global default range or override it for each playlist to calculate partial durations." },
  { title: "Daily watch planner", detail: "Turn total playlist time into days, finish date, and videos-per-day estimates from your daily minute target." },
  { title: "Copy and CSV export", detail: "Copy a readable watch-time summary or download a CSV with playlist, channel, range, duration, views, and publish date." },
  { title: "Playlist context", detail: "Review thumbnails, channel names, total views, average video length, publish dates, and sortable watch-time columns." },
  { title: "No login required", detail: "No sign-up and no account data. Playlist IDs are sent only to the serverless API that queries YouTube." },
  { title: "Instant results", detail: "Results appear in seconds. Works on desktop, tablet, and mobile browsers." }
];

const comparison = [
  { title: "Batch comparison", detail: "Measure several playlists in one run instead of calculating one playlist at a time." },
  { title: "Partial playlist math", detail: "Calculate videos 12-48, the first 20 lessons, or the last 10 uploads without changing the original playlist." },
  { title: "Planning output", detail: "Convert playlist duration into daily effort, finish date, videos per day, copyable notes, and a spreadsheet-friendly CSV." },
  { title: "Research context", detail: "Use views, publish date, average duration, channel, and thumbnail data to compare courses or content queues." }
];

const whyUse = "Whether you are planning a study schedule, estimating a tutorial series, comparing online courses, or figuring out how long a binge-watch will take, knowing the total YouTube playlist time saves real effort. Instead of scrolling through dozens or hundreds of videos to guess, this online playlist calculator gives you an accurate answer in seconds. Compare playlist duration at 1.5x speed, 2x speed, or any custom rate, then turn that watch time into a daily plan you can copy or export.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "yttime",
      url: canonical,
      inLanguage: "en",
      description
    },
    {
      "@type": "WebApplication",
      name: "yttime",
      url: canonical,
      applicationCategory: "UtilityApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript for playlist analysis",
      isAccessibleForFree: true,
      description,
      featureList: [...features, ...comparison].map((item) => `${item.title}: ${item.detail}`),
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "YouTube Playlist Length Calculator",
          item: canonical
        }
      ]
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a }
      }))
    }
  ]
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0A0D15" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.svg" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#E11D48" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="yttime" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="min-h-screen">
    <a href="#calculator" class="skip-link">Skip to calculator</a>

    <header
      class="sticky top-0 z-40 border-b border-border-dark/85 bg-background-dark/90 shadow-soft backdrop-blur"
    >
      <div class="site-frame flex items-center gap-3 py-3">
        <a href="/" class="flex items-center gap-3 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" aria-label="yttime home">
        <div class="flex size-8 items-center justify-center rounded-md bg-primary/15 text-primary ring-1 ring-primary/35">
          <svg viewBox="0 0 24 24" class="size-7" fill="currentColor" aria-hidden="true">
            <path
              d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm-2 5.8a.8.8 0 0 1 1.23-.67l5.23 3.37a.8.8 0 0 1 0 1.34l-5.23 3.37A.8.8 0 0 1 10 14.54V7.8Z"
            />
          </svg>
        </div>
        <span class="text-xl font-bold text-white">yttime</span>
        </a>

        <nav class="ml-auto hidden items-center gap-1 sm:flex" aria-label="Primary navigation">
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-warm-muted transition hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" href="#calculator">
            Calculator
          </a>
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-warm-muted transition hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" href="#seo-content">
            Guide
          </a>
        </nav>
      </div>
    </header>

    <main class="site-frame flex flex-1 flex-col gap-5 py-5 md:py-6">
      <section class="grid gap-4 py-1 md:grid-cols-[minmax(0,1fr)_minmax(320px,420px)] md:items-end">
        <div class="max-w-4xl">
          <p class="text-sm font-semibold text-primary">yttime</p>
          <h1 class="mt-2 max-w-4xl text-balance font-display text-3xl font-extrabold leading-tight text-white md:text-4xl">
            YouTube playlist length calculator
          </h1>
          <p class="mt-3 max-w-3xl text-sm leading-6 text-warm-muted">
            Paste one or many playlist links to calculate total watch time at 1x, 1.25x, 1.5x, 1.75x, 2x, or any custom speed. Compare ranges, plan daily progress, and export a summary without signing in.
          </p>
        </div>

        <aside aria-label="Calculator summary">
          <dl class="grid grid-cols-1 gap-2 sm:grid-cols-3 md:grid-cols-1">
            <div class="rounded-lg border border-border-dark bg-surface-dark/75 p-3 shadow-inset">
              <dt class="text-xs font-medium text-warm-muted">Baseline</dt>
              <dd class="mt-1 font-mono text-lg font-bold text-white">1x</dd>
            </div>
            <div class="rounded-lg border border-border-dark bg-surface-dark/75 p-3 shadow-inset">
              <dt class="text-xs font-medium text-warm-muted">Speeds</dt>
              <dd class="mt-1 font-mono text-lg font-bold text-white">1x-2x+</dd>
            </div>
            <div class="rounded-lg border border-border-dark bg-surface-dark/75 p-3 shadow-inset">
              <dt class="text-xs font-medium text-warm-muted">Plan/export</dt>
              <dd class="mt-1 font-mono text-lg font-bold text-white">CSV</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section id="calculator" aria-label="Playlist calculator">
        <App client:load />
      </section>

      <section id="seo-content" class="overflow-hidden rounded-lg border border-border-dark bg-surface-dark/75 shadow-soft">
        <ContentAccordion client:idle faq={faq} howItWorks={howItWorks} features={features} comparison={comparison} whyUse={whyUse} />
      </section>
    </main>
  </body>
</html>

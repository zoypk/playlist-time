---
import App from "../components/App";
import { ContentAccordion } from "../components/ContentAccordion";
import "../styles/global.css";

const site = "https://playlist-time.pages.dev";
const canonical = new URL("/", site).toString();
const socialImage = new URL("/og.png", site).toString();
const socialImageAlt = "playlist-time YouTube playlist length calculator with speed, range, planner, and export tools";

const title = "YouTube Playlist Length Calculator | playlist-time";
const description =
  "Calculate YouTube playlist length instantly. Compare multiple playlists, ranges, playback speeds, daily watch plans, and CSV summaries. Free, no login.";

const faq = [
  {
    q: "What should I paste into the calculator?",
    a: "Paste a normal YouTube playlist URL or the raw playlist ID. You can add one playlist for a quick total or paste several at once to compare them before choosing what to watch."
  },
  {
    q: "When should I use a video range?",
    a: "Use a range when only part of the playlist matters, such as lessons 20 through 80 in a course or the remaining videos after you have already started. The same range can apply to every playlist, or you can override it per playlist."
  },
  {
    q: "How should I choose a playback speed?",
    a: "Use the speed you actually watch at. The totals update for common speeds like 1.25x, 1.5x, 1.75x, and 2x, and custom speed helps when a course or lecture series is comfortable at a different pace."
  },
  {
    q: "How do I turn the result into a watch plan?",
    a: "After analysis, enter how many minutes you can watch per day. The planner estimates the number of days, the finish date, and roughly how many videos you need to complete each day."
  },
  {
    q: "Why can the total change later?",
    a: "Playlist totals can change when the owner adds or removes videos, or when private, deleted, or region-blocked videos are unavailable to the API. Small differences can also come from rounding seconds into readable totals."
  },
  {
    q: "What happens to the playlists I check?",
    a: "No account is required. Playlist IDs are sent to the serverless API so it can ask YouTube for video details, while saved calculator state stays in your browser session."
  }
];

const howItWorks = [
  { title: "Paste playlists", detail: "Use playlist URLs or raw IDs." },
  { title: "Set a range", detail: "Measure a whole playlist or selected videos." },
  { title: "Analyze", detail: "Fetch durations and compare totals." },
  { title: "Plan or export", detail: "Copy summaries or download CSV results." }
];

const features = [
  { title: "Batch playlist comparison", detail: "Compare several playlists in one run." },
  { title: "Speed control", detail: "Check 1x, 1.25x, 1.5x, 1.75x, 2x, or custom speed." },
  { title: "Video ranges", detail: "Calculate partial playlist durations." },
  { title: "Daily watch planner", detail: "Estimate days, finish date, and videos per day." },
  { title: "Copy and CSV export", detail: "Save playlist duration results." },
  { title: "No login required", detail: "Use the calculator without an account." }
];

const comparison = [
  { title: "Courses", detail: "Estimate study time before starting." },
  { title: "Tutorials", detail: "Measure only the lessons you need." },
  { title: "Queues", detail: "Compare playlists by watch-time." },
  { title: "Planning", detail: "Turn duration into a daily schedule." }
];

const whyUse = "Use playlist-time to estimate total YouTube playlist time, compare speeds like 1.5x or 2x, and turn the result into a simple daily plan.";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "playlist-time",
      url: canonical,
      inLanguage: "en",
      description
    },
    {
      "@type": "WebApplication",
      name: "playlist-time",
      url: canonical,
      applicationCategory: "UtilityApplication",
      operatingSystem: "Any",
      browserRequirements: "Requires JavaScript for playlist analysis",
      isAccessibleForFree: true,
      description,
      featureList: [...features, ...comparison].map((item) => `${item.title}: ${item.detail}`),
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD"
      }
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "YouTube Playlist Length Calculator",
          item: canonical
        }
      ]
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a }
      }))
    }
  ]
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0A0D15" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/icon-180.svg" />
    <link rel="mask-icon" href="/mask-icon.svg" color="#FF0000" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="playlist-time" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="min-h-screen">
    <a href="#calculator" class="skip-link">Skip to calculator</a>

    <header
      class="sticky top-0 z-40 border-b border-border-dark/85 bg-background-dark/90 shadow-soft backdrop-blur"
    >
      <div class="site-frame flex items-center gap-3 py-3">
        <a href="/" class="flex min-h-11 items-center gap-3 rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" aria-label="Playlist Time home">
        <img src="/favicon.svg" alt="" class="size-10" width="40" height="40" decoding="async" />
        <span class="text-xl font-bold text-white">Playlist Time</span>
        </a>

        <nav class="ml-auto hidden items-center gap-1 sm:flex" aria-label="Primary navigation">
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-warm-muted transition hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" href="#calculator">
            Calculator
          </a>
          <a class="rounded-md px-3 py-2 text-sm font-semibold text-warm-muted transition hover:bg-white/5 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/60" href="#seo-content">
            Guide
          </a>
        </nav>
      </div>
    </header>

    <main class="site-frame flex flex-1 flex-col gap-4 py-4 md:py-5">
      <section class="grid gap-3 py-1">
        <div class="max-w-5xl">
          <h1 class="max-w-4xl text-balance font-display text-3xl font-extrabold leading-tight text-white md:text-4xl">
            YouTube playlist length calculator
          </h1>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-warm-muted">
            Paste multiple YouTube playlist links, compare the real watch-time commitment by speed and range, then copy or export a plan without signing in.
          </p>
        </div>

        <aside aria-label="Calculator workflow">
          <dl class="grid grid-cols-3 gap-2">
            <div class="rounded-md border border-border-dark bg-surface-dark/75 px-3 py-2 shadow-inset">
              <dt class="text-[11px] font-medium text-warm-muted">Paste</dt>
              <dd class="mt-0.5 font-mono text-sm font-bold text-white">2+ lists</dd>
            </div>
            <div class="rounded-md border border-border-dark bg-surface-dark/75 px-3 py-2 shadow-inset">
              <dt class="text-[11px] font-medium text-warm-muted">Compare</dt>
              <dd class="mt-0.5 font-mono text-sm font-bold text-white">1x-3x</dd>
            </div>
            <div class="rounded-md border border-border-dark bg-surface-dark/75 px-3 py-2 shadow-inset">
              <dt class="text-[11px] font-medium text-warm-muted">Share</dt>
              <dd class="mt-0.5 font-mono text-sm font-bold text-white">CSV</dd>
            </div>
          </dl>
        </aside>
      </section>

      <section id="calculator" aria-label="Playlist calculator">
        <App client:load />
      </section>

      <section id="seo-content" class="overflow-hidden rounded-lg border border-border-dark bg-surface-dark/75 shadow-soft">
        <ContentAccordion client:idle faq={faq} howItWorks={howItWorks} features={features} whyUse={whyUse} />
      </section>
    </main>
  </body>
</html>

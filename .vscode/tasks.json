{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Astro: Dev Server",
      "type": "shell",
      "command": "bun",
      "args": ["run", "dev"],
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "Local\\s+http://localhost:[0-9]+/"
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "Local\\s+http://localhost:[0-9]+/"
          }
        }
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Astro: Build",
      "type": "shell",
      "command": "bun",
      "args": ["run", "build"],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "Astro: Preview",
      "type": "shell",
      "command": "bun",
      "args": ["run", "preview"],
      "problemMatcher": [],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Worker: Dev Server",
      "type": "shell",
      "command": "bun",
      "args": ["run", "worker:dev"],
      "problemMatcher": [],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Pages: Dev Server",
      "type": "shell",
      "command": "bun",
      "args": ["run", "pages:dev"],
      "problemMatcher": [],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Pages: Deploy",
      "type": "shell",
      "command": "bun",
      "args": ["run", "deploy:pages"],
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      }
    },
    {
      "label": "Dev: Pages + Wrangler",
      "dependsOn": [
        "Astro: Dev Server",
        "Wrangler: Pages Dev"
      ],
      "problemMatcher": [],
      "group": "build",
      "isBackground": true
    },
    {
      "label": "Wrangler: Pages Dev",
      "type": "shell",
      "command": "bunx",
      "args": [
        "wrangler",
        "pages",
        "dev",
        "./dist",
        "--compatibility-date=2025-01-01"
      ],
      "problemMatcher": [],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
